@page
@model ShopEasy.Pages.Admin.Orders.DetailsModel
@{
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <h1>Order Details</h1>
    <a asp-page="Index" class="btn btn-secondary btn-custom">⬅️ Back to Orders</a>
</div>

@if (Model.Order == null)
{
    <div class="alert alert-danger">Order not found.</div>
}
else
{
    <div class="row">
        <div class="col-md-6">
            <div class="stat-card">
                <h5>Order Information</h5>
                <table class="table table-borderless">
                    <tr>
                        <td><strong>Order ID:</strong></td>
                        <td>#@Model.Order.Id</td>
                    </tr>
                    <tr>
                        <td><strong>Order Date:</strong></td>
                        <td>@Model.Order.OrderDate.ToString("MMM dd, yyyy hh:mm tt")</td>
                    </tr>
                    <tr>
                        <td><strong>Status:</strong></td>
                        <td>
                            <span class="badge bg-warning text-dark">@Model.Order.Status</span>
                        </td>
                    </tr>
                    <tr>
                        <td><strong>Total Amount:</strong></td>
                        <td><strong>₹@Model.Order.TotalAmount.ToString("F2")</strong></td>
                    </tr>
                </table>
            </div>
        </div>

        <div class="col-md-6">
            <div class="stat-card">
                <h5>Customer Information</h5>
                <table class="table table-borderless">
                    <tr>
                        <td><strong>Name:</strong></td>
                        <td>@Model.Order.Customer.customer_Name</td>
                    </tr>
                    <tr>
                        <td><strong>Email:</strong></td>
                        <td>@Model.Order.Customer.customer_Email</td>
                    </tr>
                    <tr>
                        <td><strong>Phone:</strong></td>
                        <td>@(Model.Order.Customer.customer_Phone ?? "-")</td>
                    </tr>
                    <tr>
                        <td><strong>Address:</strong></td>
                        <td>@(Model.Order.Customer.customer_Address ?? "-")</td>
                    </tr>
                </table>
            </div>
        </div>
    </div>

    <div class="row mt-3">
        <div class="col-md-12">
            <div class="stat-card">
                <h5>Order Items</h5>
                @if (Model.Order.OrderItems != null && Model.Order.OrderItems.Count > 0)
                {
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th>Product</th>
                                    <th>Quantity</th>
                                    <th>Unit Price</th>
                                    <th>Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Order.OrderItems)
                                {
                                    <tr>
                                        <td>@item.Product.Product_Name</td>
                                        <td>@item.Quantity</td>
                                        <td>₹@item.Price.ToString("F2")</td>
                                        <td>₹@(item.Quantity * item.Price).ToString("F2")</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr class="table-light">
                                    <td colspan="3" class="text-end"><strong>Total:</strong></td>
                                    <td><strong>₹@Model.Order.TotalAmount.ToString("F2")</strong></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted">No items in this order.</p>
                }
            </div>
        </div>
    </div>
}
