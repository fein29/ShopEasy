@page
@model ShopEasy.Pages.Admin.DashboardModel
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <h1>Dashboard</h1>
    <p class="text-muted">Welcome to ShopEasy Admin Panel</p>
</div>

<div class="row">
    <div class="col-md-3">
        <div class="stat-card">
            <h6 class="text-muted">Total Products</h6>
            <div class="stat-number">@Model.TotalProducts</div>
            <small class="text-success">Updated just now</small>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <h6 class="text-muted">Total Categories</h6>
            <div class="stat-number">@Model.TotalCategories</div>
            <small class="text-success">Updated just now</small>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <h6 class="text-muted">Total Customers</h6>
            <div class="stat-number">@Model.TotalCustomers</div>
            <small class="text-success">Updated just now</small>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <h6 class="text-muted">Total Orders</h6>
            <div class="stat-number">@Model.TotalOrders</div>
            <small class="text-success">Updated just now</small>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-md-12">
        <div class="stat-card">
            <h5 class="mb-3">Quick Actions</h5>
            <a asp-page="/Admin/Products/Create" class="btn btn-primary btn-custom">
                ➕ Add New Product
            </a>
            <a asp-page="/Admin/Categories/Create" class="btn btn-success btn-custom">
                ➕ Add New Category
            </a>
            <a asp-page="/Admin/Orders/Index" class="btn btn-info btn-custom">
                📋 View All Orders
            </a>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-md-6">
        <div class="stat-card">
            <h5 class="mb-3">Recent Orders</h5>
            @if(Model.RecentOrders != null && Model.RecentOrders.Count > 0)
            {
                <div class="table-responsive">
                    <table class="table table-sm table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Order ID</th>
                                <th>Customer</th>
                                <th>Total</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach(var order in Model.RecentOrders)
                            {
                                <tr>
                                    <td>@order.Id</td>
                                    <td>@order.Customer.customer_Name</td>
                                    <td>₹@order.TotalAmount.ToString("F2")</td>
                                    <td>
                                        <span class="badge bg-warning text-dark">@order.Status</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted">No recent orders</p>
            }
        </div>
    </div>

    <div class="col-md-6">
        <div class="stat-card">
            <h5 class="mb-3">Low Stock Products</h5>
            @if(Model.LowStockProducts != null && Model.LowStockProducts.Count > 0)
            {
                <div class="table-responsive">
                    <table class="table table-sm table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Product</th>
                                <th>Stock</th>
                                <th>Price</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach(var product in Model.LowStockProducts)
                            {
                                <tr>
                                    <td>@product.Product_Name</td>
                                    <td>
                                        <span class="badge bg-danger">@product.Stock</span>
                                    </td>
                                    <td>₹@product.Product_price.ToString("F2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted">All products have sufficient stock</p>
            }
        </div>
    </div>
</div>
