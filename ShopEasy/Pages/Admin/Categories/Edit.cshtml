@page
@model ShopEasy.Pages.Admin.Categories.EditModel
@{
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <h1>Edit Category</h1>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="stat-card">
            @if (Model.Category == null)
            {
                <div class="alert alert-danger">Category not found.</div>
            }
            else
            {
                <form method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Category.CategoryId" />

                    <div class="mb-3">
                        <label asp-for="Category.Name" class="form-label">Category Name *</label>
                        <input asp-for="Category.Name" class="form-control" required />
                        <span asp-validation-for="Category.Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Category.Description" class="form-label">Description</label>
                        <textarea asp-for="Category.Description" class="form-control" rows="4"></textarea>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary btn-custom">💾 Update Category</button>
                        <a asp-page="Index" class="btn btn-secondary btn-custom">❌ Cancel</a>
                    </div>
                </form>
            }
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
