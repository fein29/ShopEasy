@page
@model ShopEasy.Pages.Admin.Categories.IndexModel
@{
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <h1>Categories Management</h1>
    <a asp-page="Create" class="btn btn-primary btn-custom">
        ➕ Add New Category
    </a>
</div>

<div class="stat-card">
    @if (Model.Categories != null && Model.Categories.Count > 0)
    {
        <div class="table-responsive">
            <table class="table table-hover table-striped">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Description</th>
                        <th>Products</th>
                        <th>Created</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var category in Model.Categories)
                    {
                        <tr>
                            <td>@category.CategoryId</td>
                            <td><strong>@category.Name</strong></td>
                            <td>@(string.IsNullOrEmpty(category.Description) ? "-" : category.Description.Substring(0, Math.Min(30, category.Description.Length)) + "...")</td>
                            <td>
                                <span class="badge bg-info">
                                    @(category.Products?.Count ?? 0)
                                </span>
                            </td>
                            <td>@category.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td>
                                <a asp-page="Edit" asp-route-id="@category.CategoryId" class="btn btn-sm btn-warning btn-custom">✏️ Edit</a>
                                <a asp-page="Delete" asp-route-id="@category.CategoryId" class="btn btn-sm btn-danger btn-custom" onclick="return confirm('Are you sure?');">🗑️ Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            No categories found. <a asp-page="Create">Create one now</a>
        </div>
    }
</div>
