@page
@model ShopEasy.Pages.Admin.Products.IndexModel
@{
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <h1>Products Management</h1>
    <a asp-page="Create" class="btn btn-primary btn-custom">
        ➕ Add New Product
    </a>
</div>

<div class="stat-card">
    @if (Model.Products != null && Model.Products.Count > 0)
    {
        <div class="table-responsive">
            <table class="table table-hover table-striped">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Category</th>
                        <th>Price</th>
                        <th>Stock</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var product in Model.Products)
                    {
                        <tr>
                            <td>@product.ProductId</td>
                            <td><strong>@product.Product_Name</strong></td>
                            <td>@product.Category?.Name ?? "-"</td>
                            <td>₹@product.Product_price.ToString("F2")</td>
                            <td>
                                @if (product.Stock > 20)
                                {
                                    <span class="badge bg-success">@product.Stock</span>
                                }
                                else if (product.Stock > 5)
                                {
                                    <span class="badge bg-warning text-dark">@product.Stock</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">@product.Stock</span>
                                }
                            </td>
                            <td>
                                @if (product.Stock > 0)
                                {
                                    <span class="badge bg-info">Available</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Out of Stock</span>
                                }
                            </td>
                            <td>@product.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td>
                                <a asp-page="Edit" asp-route-id="@product.ProductId" class="btn btn-sm btn-warning btn-custom">✏️ Edit</a>
                                <a asp-page="Delete" asp-route-id="@product.ProductId" class="btn btn-sm btn-danger btn-custom" onclick="return confirm('Are you sure?');">🗑️ Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            No products found. <a asp-page="Create">Create one now</a>
        </div>
    }
</div>
