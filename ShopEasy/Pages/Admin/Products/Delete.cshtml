@page
@model ShopEasy.Pages.Admin.Products.DeleteModel
@{
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <h1>Delete Product</h1>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="stat-card alert alert-warning">
            @if (Model.Product == null)
            {
                <div class="alert alert-danger">Product not found.</div>
            }
            else
            {
                <p><strong>Are you sure you want to delete this product?</strong></p>
                <p>
                    <strong>Name:</strong> @Model.Product.Product_Name<br />
                    <strong>Price:</strong> ₹@Model.Product.Product_price.ToString("F2")<br />
                    <strong>Stock:</strong> @Model.Product.Stock
                </p>
                <p class="text-danger"><em>This action cannot be undone.</em></p>

                <form method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Product.ProductId" />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger btn-custom">🗑️ Delete</button>
                        <a asp-page="Index" class="btn btn-secondary btn-custom">❌ Cancel</a>
                    </div>
                </form>
            }
        </div>
    </div>
</div>
