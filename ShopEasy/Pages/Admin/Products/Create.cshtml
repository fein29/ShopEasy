@page
@model ShopEasy.Pages.Admin.Products.CreateModel
@{
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <h1>Add New Product</h1>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="stat-card">
            <form method="post">
                <div class="mb-3">
                    <label asp-for="Product.Product_Name" class="form-label">Product Name *</label>
                    <input asp-for="Product.Product_Name" class="form-control" placeholder="Enter product name" required />
                    <span asp-validation-for="Product.Product_Name" class="text-danger small"></span>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="Product.Product_price" class="form-label">Price (₹) *</label>
                            <input asp-for="Product.Product_price" type="number" step="0.01" class="form-control" placeholder="0.00" required />
                            <span asp-validation-for="Product.Product_price" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="Product.Stock" class="form-label">Stock *</label>
                            <input asp-for="Product.Stock" type="number" class="form-control" placeholder="0" required />
                            <span asp-validation-for="Product.Stock" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Product.cat_id" class="form-label">Category *</label>
                    <select asp-for="Product.cat_id" class="form-control" required>
                        <option value="">-- Select Category --</option>
                        @foreach (var category in Model.Categories)
                        {
                            <option value="@category.CategoryId">@category.Name</option>
                        }
                    </select>
                    <span asp-validation-for="Product.cat_id" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Product.Product_Description" class="form-label">Description</label>
                    <textarea asp-for="Product.Product_Description" class="form-control" rows="5" placeholder="Enter product description"></textarea>
                </div>

                <div class="mb-3">
                    <label asp-for="Product.Product_image" class="form-label">Image URL</label>
                    <input asp-for="Product.Product_image" class="form-control" placeholder="https://example.com/image.jpg" />
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary btn-custom">💾 Save Product</button>
                    <a asp-page="Index" class="btn btn-secondary btn-custom">❌ Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
