@model ShopEasy.ViewModels.ProductsViewModel

@{
    ViewData["Title"] = "Products - ShopEasy";
}

<style>
    :root {
        --primary-color: #667eea;
        --secondary-color: #764ba2;
    }

    /* Navigation Bar */
    .navbar {
        background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }
    .navbar-brand {
        font-size: 24px;
        font-weight: bold;
        color: white !important;
    }
    .nav-link {
        color: white !important;
        margin: 0 10px;
        transition: opacity 0.3s;
    }
    .nav-link:hover {
        opacity: 0.8;
    }

    /* Page Header */
    .page-header {
        background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%);
        color: white;
        padding: 40px 20px;
        text-align: center;
        margin-bottom: 40px;
        border-radius: 0;
    }
    .page-header h1 {
        margin-bottom: 10px;
        font-size: 36px;
    }

    /* Filter Section */
    .filter-section {
        background: #f8f9fa;
        padding: 20px;
        border-radius: 8px;
        margin-bottom: 30px;
    }
    .filter-title {
        font-weight: 600;
        margin-bottom: 15px;
        color: #333;
    }
    .category-filter {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }
    .category-btn {
        background: white;
        border: 2px solid #ddd;
        color: #333;
        padding: 10px 15px;
        border-radius: 6px;
        cursor: pointer;
        transition: all 0.3s;
        text-decoration: none;
        font-size: 14px;
        font-weight: 500;
    }
    .category-btn:hover,
    .category-btn.active {
        background: var(--primary-color);
        color: white;
        border-color: var(--primary-color);
        text-decoration: none;
    }

    /* Search Results Info */
    .search-info {
        background: #e7f3ff;
        border-left: 4px solid var(--primary-color);
        padding: 15px;
        border-radius: 4px;
        margin-bottom: 20px;
        color: #333;
    }

    /* Product Card */
    .product-card {
        background: white;
        border: 1px solid #e0e0e0;
        border-radius: 10px;
        overflow: hidden;
        transition: all 0.3s;
        height: 100%;
        display: flex;
        flex-direction: column;
    }
    .product-card:hover {
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.15);
        transform: translateY(-5px);
    }
    .product-image {
        width: 100%;
        height: 220px;
        background: #f5f5f5;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 60px;
        overflow: hidden;
    }
    .product-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .product-info {
        padding: 18px;
        flex: 1;
        display: flex;
        flex-direction: column;
    }
    .product-category {
        font-size: 11px;
        color: var(--primary-color);
        font-weight: 600;
        margin-bottom: 5px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .product-name {
        font-size: 16px;
        font-weight: 600;
        color: #333;
        margin-bottom: 10px;
        min-height: 40px;
        line-height: 1.3;
    }
    .product-description {
        font-size: 13px;
        color: #666;
        margin-bottom: 10px;
        line-height: 1.4;
        flex: 1;
    }
    .product-price {
        font-size: 22px;
        color: var(--primary-color);
        font-weight: bold;
        margin-bottom: 10px;
    }
    .product-stock {
        font-size: 12px;
        margin-bottom: 15px;
        font-weight: 500;
    }
    .stock-available {
        color: #28a745;
    }
    .stock-limited {
        color: #ffc107;
    }
    .stock-unavailable {
        color: #dc3545;
    }
    .product-actions {
        display: flex;
        gap: 8px;
        margin-top: auto;
    }
    .btn-details {
        flex: 1;
        padding: 11px;
        background: var(--primary-color);
        color: white;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        font-weight: 600;
        font-size: 13px;
        text-decoration: none;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s;
    }
    .btn-details:hover {
        background: var(--secondary-color);
        color: white;
        text-decoration: none;
    }
    .btn-cart {
        flex: 1;
        padding: 11px;
        background: #28a745;
        color: white;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        font-weight: 600;
        font-size: 13px;
        transition: all 0.3s;
    }
    .btn-cart:hover {
        background: #218838;
    }

    /* No Products */
    .no-products {
        text-align: center;
        padding: 60px 20px;
        color: #666;
    }
    .no-products-icon {
        font-size: 80px;
        margin-bottom: 20px;
    }
    .no-products h3 {
        color: #333;
        margin-bottom: 10px;
    }

    /* Results Count */
    .results-count {
        color: #666;
        font-size: 14px;
        margin-bottom: 20px;
        padding: 10px;
        background: #f8f9fa;
        border-radius: 6px;
    }

    /* Footer */
    .footer {
        background: #f8f9fa;
        border-top: 1px solid #e0e0e0;
        padding: 30px 20px;
        margin-top: 50px;
        color: #666;
    }
    .footer h6 {
        font-weight: 600;
        color: #333;
        margin-bottom: 15px;
    }
    .footer a {
        color: var(--primary-color);
        text-decoration: none;
    }
    .footer a:hover {
        text-decoration: underline;
    }
</style>

<!-- Navigation Bar -->
<nav class="navbar navbar-expand-lg navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="@Url.Action("Index", "Home")">🏪 ShopEasy</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto">
                <li class="nav-item">
                    <a class="nav-link" href="@Url.Action("Index", "Home")">🏠 Home</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link active" href="@Url.Action("Products", "Home")">📦 Products</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#">📋 My Orders</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#">🛒 Cart</a>
                </li>
                @if (User.Identity.IsAuthenticated && !User.IsInRole("Administrator"))
                {
                    <li class="nav-item">
                        <a class="nav-link" href="/Account/Profile">👤 Profile</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Account/Logout">🚪 Logout</a>
                    </li>
                }
                else if (!User.Identity.IsAuthenticated)
                {
                    <li class="nav-item">
                        <a class="nav-link" href="/Account/Login">🔓 Login</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Account/Register">📝 Register</a>
                    </li>
                }
            </ul>
        </div>
    </div>
</nav>

<!-- Page Header -->
<div class="page-header">
    <h1>📦 All Products</h1>
    <p>Browse our complete collection</p>
</div>

<!-- Main Content -->
<div class="container">
    <!-- Filter Section -->
    <div class="filter-section">
        <div class="filter-title">🏷️ Filter by Category</div>
        <div class="category-filter">
            <a href="@Url.Action("Products", "Home")" 
               class="category-btn @(Model.SelectedCategoryId == null ? "active" : "")">
                📦 All Products
            </a>
            @foreach (var category in Model.Categories)
            {
                <a href="@Url.Action("Products", "Home", new { categoryId = category.CategoryId, searchTerm = Model.SearchTerm })" 
                   class="category-btn @(Model.SelectedCategoryId == category.CategoryId ? "active" : "")">
                    📂 @category.Name
                </a>
            }
        </div>
    </div>

    <!-- Search Info -->
    @if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
    {
        <div class="search-info">
            🔍 Search results for: <strong>"@Model.SearchTerm"</strong>
            <a href="@Url.Action("Products", "Home")" style="float: right; color: var(--primary-color);">Clear Search</a>
        </div>
    }

    <!-- Results Count -->
    @if (Model.Products.Count > 0)
    {
        <div class="results-count">
            Found <strong>@Model.Products.Count</strong> product(s)
        </div>
    }

    <!-- Products Grid -->
    @if (Model.Products.Count > 0)
    {
        <div class="row g-4 mb-5">
            @foreach (var product in Model.Products)
            {
                <div class="col-md-6 col-lg-4 col-xl-3">
                    <div class="product-card">
                        <div class="product-image">
                            @if (!string.IsNullOrEmpty(product.Product_image))
                            {
                                <img src="@product.Product_image" alt="@product.Product_Name" />
                            }
                            else
                            {
                                <span>📸</span>
                            }
                        </div>
                        <div class="product-info">
                            <div class="product-category">@product.Category?.Name</div>
                            <h5 class="product-name">@product.Product_Name</h5>
                            @if (!string.IsNullOrEmpty(product.Product_Description))
                            {
                                <p class="product-description">
                                    @(product.Product_Description.Length > 60 ? 
                                        product.Product_Description.Substring(0, 60) + "..." : 
                                        product.Product_Description)
                                </p>
                            }
                            <div class="product-price">₹@product.Product_price.ToString("F2")</div>
                            <div class="product-stock">
                                @if (product.Stock > 10)
                                {
                                    <span class="stock-available">✓ In Stock (@product.Stock available)</span>
                                }
                                else if (product.Stock > 0)
                                {
                                    <span class="stock-limited">⚠️ Limited Stock (@product.Stock left)</span>
                                }
                                else
                                {
                                    <span class="stock-unavailable">✗ Out of Stock</span>
                                }
                            </div>
                            <div class="product-actions">
                                <a href="#" class="btn-details">👁️ View</a>
                                <button class="btn-cart" onclick="alert('Add to cart functionality coming soon!')">
                                    🛒 Cart
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="no-products">
            <div class="no-products-icon">📭</div>
            <h3>No Products Found</h3>
            <p>
                @if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
                {
                    <span>No products match your search for "@Model.SearchTerm". Try a different search term.</span>
                }
                else if (Model.SelectedCategoryId.HasValue)
                {
                    <span>No products available in this category.</span>
                }
                else
                {
                    <span>No products are currently available. Please check back soon!</span>
                }
            </p>
            <a href="@Url.Action("Products", "Home")" class="btn btn-primary mt-3">
                🏠 Back to Products
            </a>
        </div>
    }
</div>

<!-- Footer -->
<footer class="footer">
    <div class="container">
        <div class="row">
            <div class="col-md-3">
                <h6>About ShopEasy</h6>
                <p style="font-size: 14px;">Your trusted online shopping destination for quality products.</p>
            </div>
            <div class="col-md-3">
                <h6>Quick Links</h6>
                <ul style="list-style: none; padding: 0;">
                    <li><a href="@Url.Action("Products", "Home")">Products</a></li>
                    <li><a href="@Url.Action("Index", "Home")">Home</a></li>
                    <li><a href="#">Contact Us</a></li>
                </ul>
            </div>
            <div class="col-md-3">
                <h6>Customer Service</h6>
                <ul style="list-style: none; padding: 0;">
                    <li><a href="#">Shipping Info</a></li>
                    <li><a href="#">Returns</a></li>
                    <li><a href="#">FAQ</a></li>
                </ul>
            </div>
            <div class="col-md-3">
                <h6>Follow Us</h6>
                <p style="font-size: 14px;">
                    <a href="#">Facebook</a> | 
                    <a href="#">Twitter</a> | 
                    <a href="#">Instagram</a>
                </p>
            </div>
        </div>
        <hr />
        <p style="text-align: center; font-size: 12px; color: #999; margin-bottom: 0;">
            © 2025 ShopEasy. All rights reserved.
        </p>
    </div>
</footer>
